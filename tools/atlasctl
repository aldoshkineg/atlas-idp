#!/usr/bin/env bash
set -euo pipefail

# atlasctl — Atlas IDP workload management CLI
# Usage:
#   atlasctl new <app> --group <group> --repo <url> [options]
#   atlasctl seed <group>/<app> [--dry-run] [--force]
#   atlasctl enable <group>/<app> [--dry-run] [--sync] [--push]
#   atlasctl disable <group>/<app> [--dry-run] [--sync] [--push]
#   atlasctl delete <group>/<app> [--dry-run] [-y]
#   atlasctl status <group>/<app> [--json]
#   atlasctl list [--json]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
TEMPLATES_DIR="${REPO_ROOT}/templates/gold"

usage() {
  cat <<USAGE
atlasctl — Atlas IDP workload management

Commands:
  new       Scaffold a new workload structure
  seed      Provision DB + bucket + write secrets to Vault
  enable    Enable workload in GitOps
  disable   Disable workload from GitOps
  delete    Delete workload directory (only if not enabled)
  status    Show workload status
  list      List all workloads

atlasctl new <app> --group <group> --repo <url> [options]
  Required:
    --group <group>    Team/group name (e.g., aldoshkineg)
    --repo <url>       Application repository URL

  Options:
    --namespace <ns>   Kubernetes namespace (default: <group>-<app>)
    --repo-path <p>    Path within repo for manifests (default: .)
    --helm             Use Helm chart
    --helm-values <s>  Inline Helm values string or file path
    --sa <sas>         Service accounts for Vault auth (comma-sep, default: <app>)
    --yes, -y          Skip confirmation prompt

atlasctl seed <group>/<app> [options]
  Provisions PostgreSQL database, MinIO bucket, and writes secrets to Vault.

  Options:
    --dry-run          Preview changes without executing
    --force            Skip validation checks

atlasctl enable <group>/<app> [options]
  Creates ArgoCD Application in gitops/ and adds gateway listener.

  Options:
    --dry-run          Preview changes without executing
    --sync             Commit changes to git
    --push             Push commits to remote (implies --sync)
    --force            Overwrite existing gitops Application
    --yes, -y          Skip confirmation prompt

atlasctl disable <group>/<app> [options]
  Removes gateway listener and ArgoCD Application from gitops/.
  Does NOT delete the workloads/<group>/<app>/ directory.

  Options:
    --dry-run          Preview changes without executing
    --sync             Commit changes to git
    --push             Push commits to remote (implies --sync)
    --yes, -y          Skip confirmation prompt

atlasctl delete <group>/<app> [options]
  Deletes the workloads/<group>/<app>/ directory.
  Refuses if the workload is still enabled (has gitops file).

  Options:
    --dry-run          Preview changes without executing
    --yes, -y          Skip confirmation prompt

atlasctl status <group>/<app> [options]
  Shows workload status (features, enabled, gateway listener).

  Options:
    --json             Output as JSON

atlasctl list [options]
  Lists all workloads with features and enabled status.

  Options:
    --json             Output as JSON

Examples:
  atlasctl new seal --group aldoshkineg --repo https://github.com/aldoshkineg/atlas-idp-seal.git --repo-path charts/seal --helm --secrets --ingress --monitoring
  atlasctl seed aldoshkineg/seal
  atlasctl seed aldoshkineg/seal --dry-run
  atlasctl enable aldoshkineg/seal --dry-run
  atlasctl enable aldoshkineg/seal --sync --push
  atlasctl disable aldoshkineg/seal -y --sync --push
  atlasctl delete aldoshkineg/seal --dry-run
  atlasctl delete aldoshkineg/seal -y
  atlasctl status aldoshkineg/seal
  atlasctl status aldoshkineg/seal --json
  atlasctl list
  atlasctl list --json
USAGE
}

die() { echo "Error: $*" >&2; exit 1; }

# --- Rendering ---
render_template() {
  local src="$1" dst="$2"
  local content
  content="$(< "$src")"

  content="${content//"{{APP}}"/$APP}"
  content="${content//"{{APP_UC}}"/$APP_UC}"
  content="${content//"{{GROUP}}"/$GROUP}"
  content="${content//"{{GROUP_UC}}"/$GROUP_UC}"
  content="${content//"{{NAMESPACE}}"/$NAMESPACE}"
  content="${content//"{{REPO_URL}}"/$REPO_URL}"
  content="${content//"{{REPO_PATH}}"/$REPO_PATH}"
  content="${content//"{{CHART_REPO}}"/${CHART_REPO:-$REPO_URL}}"
  content="${content//"{{CHART_REVISION}}"/${CHART_REVISION:-main}}"
  content="${content//"{{CHART_PATH}}"/${CHART_PATH:-}}"
  content="${content//"{{TARGET_REVISION}}"/${TARGET_REVISION:-main}}"

  if [ -n "${HOSTNAME:-}" ]; then
    content="${content//"{{HOSTNAME}}"/$HOSTNAME}"
  fi

  if [ "${HELM:-false}" = "true" ]; then
    local helm_block=$'helm:\n      values: |\n'"$HELM_VALUES_INDENTED"
    content="${content//"{{REPO_HELM_SETTINGS}}"/$helm_block}"
  else
    content="${content//"{{REPO_HELM_SETTINGS}}"/}"
  fi

  if [ -n "${GITOPS_HELM_VALUES:-}" ]; then
    local gitops_helm_block=$'      helm:\n        values: |\n'"$GITOPS_HELM_VALUES"
    content="${content//"{{GITOPS_HELM_SETTINGS}}"/$gitops_helm_block}"
  else
    content="${content//"{{GITOPS_HELM_SETTINGS}}"/}"
  fi

  if [ -n "${SERVICE_ACCOUNTS:-}" ]; then
    content="${content//"{{SERVICE_ACCOUNTS}}"/$SERVICE_ACCOUNTS}"
  fi

  if [ "$dst" = "-" ]; then
    echo "$content"
  else
    echo "$content" > "$dst"
  fi
}

prompt_confirm() {
  local msg="$1"
  if [ "${SKIP_CONFIRM:-false}" = "true" ]; then
    return 0
  fi
  read -r -p "$msg [y/N] " reply
  case "$reply" in
    [yY]|[yY][eE][sS]) return 0 ;;
    *) return 1 ;;
  esac
}

# --- Utility: kubectl exec ---
kexec() {
  kubectl exec "$@" 2>/dev/null
}

# --- Utility: vault cmd inside vault-0 pod ---
vault0() {
  local VAULT_TOKEN
  VAULT_TOKEN="$(kubectl get secret -n vault vault-unseal-keys -o jsonpath='{.data.vault-root}' 2>/dev/null | base64 -d || true)"
  [ -z "$VAULT_TOKEN" ] && return 1
  kubectl exec -n vault vault-0 -- env VAULT_TOKEN="${VAULT_TOKEN}" VAULT_ADDR=http://127.0.0.1:8200 vault "$@" 2>/dev/null || true
}

# --- Utility: read K8s secret key ---
ksecret() {
  kubectl get secret -n "$1" "$2" -o jsonpath="{.data.$3}" 2>/dev/null | base64 -d || echo ""
}

# --- Detect features in a workload directory ---
detect_features() {
  local dir="$1"
  local features=""
  [ -f "${dir}.secret-seed" ] || [ -f "${dir}vault/policy.hcl" ] && features+="secrets "
  [ -f "${dir}gateway.yaml" ] || [ -f "${dir}infra/gateway.yaml" ] && features+="gateway "
  [ -f "${dir}monitoring/prometheus-rule.yaml" ] && features+="monitoring "
  echo "$features"
}

# --- Color helpers ---
color() {
  local code="$1" text="$2"
  if [ -t 1 ]; then
    echo -e "\033[${code}m${text}\033[0m"
  else
    echo "$text"
  fi
}
green()  { color "0;32" "$1"; }
yellow() { color "0;33" "$1"; }
red()    { color "0;31" "$1"; }

# --- Command: new ---
cmd_new() {
  APP=""
  GROUP=""
  REPO_URL=""
  NAMESPACE=""
  REPO_PATH="."
  HELM=false
  HELM_VALUES=""
  SERVICE_ACCOUNTS=""
  SKIP_CONFIRM=false
  HOSTNAME=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --group) GROUP="$2"; shift 2 ;;
      --repo) REPO_URL="$2"; shift 2 ;;
      --namespace) NAMESPACE="$2"; shift 2 ;;
      --repo-path) REPO_PATH="$2"; shift 2 ;;
      --helm) HELM=true; shift ;;
      --helm-values) HELM_VALUES="$2"; shift 2 ;;
      --sa) SERVICE_ACCOUNTS="$2"; shift 2 ;;
      --yes|-y) SKIP_CONFIRM=true; shift ;;
      --*|-*) die "Unknown option: $1" ;;
      *)
        [ -n "$APP" ] && die "Unexpected argument: $1"
        APP="$1"
        shift
        ;;
    esac
  done

  [ -z "$APP" ] && die "App name is required"
  [ -z "$GROUP" ] && die "--group is required"
  [ -z "$REPO_URL" ] && die "--repo is required"

  APP_UC="$(echo "$APP" | tr '[:lower:]' '[:upper:]' | tr '-' '_')"
  GROUP_UC="$(echo "$GROUP" | tr '[:lower:]' '[:upper:]' | tr '-' '_')"
  [ -z "$NAMESPACE" ] && NAMESPACE="${GROUP}-${APP}"
  [ -z "$SERVICE_ACCOUNTS" ] && SERVICE_ACCOUNTS="$APP"

  local WORKLOAD_DIR="${REPO_ROOT}/workloads/${GROUP}/${APP}"

  if [ -d "$WORKLOAD_DIR" ]; then
    die "Workload already exists: $WORKLOAD_DIR"
  fi

  local HELM_VALUES_INDENTED=""
  local GITOPS_HELM_VALUES=""
  if [ "$HELM" = "true" ] && [ -n "$HELM_VALUES" ]; then
    if [ -f "$HELM_VALUES" ]; then
      HELM_VALUES_INDENTED="$(sed 's/^/        /' "$HELM_VALUES")"
      GITOPS_HELM_VALUES="$(sed 's/^/          /' "$HELM_VALUES")"
    else
      HELM_VALUES_INDENTED="$(echo "$HELM_VALUES" | sed 's/^/        /')"
      GITOPS_HELM_VALUES="$(echo "$HELM_VALUES" | sed 's/^/          /')"
    fi
  fi

  HOSTNAME="${APP}.atlas"

  echo "---"
  echo "Scaffolding new workload:"
  echo "  App:       $APP"
  echo "  Group:     $GROUP"
  echo "  Namespace: $NAMESPACE"
  echo "  Repo:      $REPO_URL (path: $REPO_PATH)"
  echo "---"

  prompt_confirm "Create workload?" || die "Aborted"

  mkdir -p "$WORKLOAD_DIR"

  render_template "${TEMPLATES_DIR}/app.yaml.tmpl" "${WORKLOAD_DIR}/app.yaml"
  echo "  [app.yaml] Created"

  mkdir -p "${WORKLOAD_DIR}/vault"
  render_template "${TEMPLATES_DIR}/vault/policy.hcl.tmpl" "${WORKLOAD_DIR}/vault/policy.hcl"
  render_template "${TEMPLATES_DIR}/vault/k8s-auth-role.yaml.tmpl" "${WORKLOAD_DIR}/vault/k8s-auth-role.yaml"
  render_template "${TEMPLATES_DIR}/vault/seed-mapping.conf.tmpl" "${WORKLOAD_DIR}/vault/seed-mapping.conf"
  render_template "${TEMPLATES_DIR}/secrets.yaml.tmpl" "${WORKLOAD_DIR}/secrets.yaml"

  local DB_PASS S3_ACCESS S3_SECRET REDIS_PASS
  DB_PASS=$(openssl rand -base64 24 2>/dev/null || echo "changeme")
  S3_ACCESS=$(openssl rand -hex 16 2>/dev/null || echo "changeme")
  S3_SECRET=$(openssl rand -base64 32 2>/dev/null || echo "changeme")
  REDIS_PASS=$(openssl rand -base64 24 2>/dev/null || echo "changeme")

  cat > "${WORKLOAD_DIR}/.secret-seed" <<EOF
# ${GROUP}/${APP} — atlasctl seed environment file
# Auto-generated by atlasctl new. Edit values before running atlasctl seed.
#
# Format: KEY=value
VL_${GROUP_UC}_${APP_UC}_DB_PASSWORD=${DB_PASS}
VL_${GROUP_UC}_${APP_UC}_S3_ACCESS_KEY=${S3_ACCESS}
VL_${GROUP_UC}_${APP_UC}_S3_SECRET_KEY=${S3_SECRET}
VL_${GROUP_UC}_${APP_UC}_REDIS_PASSWORD=${REDIS_PASS}
EOF
  echo "  [secrets] Created vault/ + secrets.yaml + .secret-seed"

  mkdir -p "${WORKLOAD_DIR}/monitoring"
  render_template "${TEMPLATES_DIR}/monitoring/pod-monitor.yaml.tmpl" "${WORKLOAD_DIR}/monitoring/pod-monitor.yaml"
  render_template "${TEMPLATES_DIR}/monitoring/prometheus-rule.yaml.tmpl" "${WORKLOAD_DIR}/monitoring/prometheus-rule.yaml"
  echo "  [monitoring] Created PodMonitor + PrometheusRule"

  mkdir -p "${WORKLOAD_DIR}/infra"
  render_template "${TEMPLATES_DIR}/infra/gateway.yaml.tmpl" "${WORKLOAD_DIR}/infra/gateway.yaml"
  render_template "${TEMPLATES_DIR}/infra/network-policy.yaml.tmpl" "${WORKLOAD_DIR}/infra/network-policy.yaml"
  render_template "${TEMPLATES_DIR}/infra/resource-quota.yaml.tmpl" "${WORKLOAD_DIR}/infra/resource-quota.yaml"
  echo "  [infra] Created gateway.yaml + NetworkPolicy + ResourceQuota"

  render_template "${TEMPLATES_DIR}/README.md.tmpl" "${WORKLOAD_DIR}/README.md"
  echo "  [README.md] Created"
  echo ""
  echo "=== Workload ${GROUP}/${APP} scaffolded ==="
  echo ""
  echo "Next steps:"
  echo "  1. Review and customize files in workloads/${GROUP}/${APP}/"
  echo "  2. Edit .secret-seed if needed (passwords already generated)"
  echo "  3. Run: atlasctl seed ${GROUP}/${APP}"
  echo "  4. Run: atlasctl enable ${GROUP}/${APP} [--sync]"
}

# --- Command: seed ---
cmd_seed() {
  local FORCE=false
  local DRY_RUN=false
  local WORKLOAD=""
  SKIP_CONFIRM=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --force) FORCE=true; shift ;;
      --dry-run) DRY_RUN=true; shift ;;
      -y|--yes) SKIP_CONFIRM=true; shift ;;
      --*|-*) die "Unknown option: $1" ;;
      *)
        [ -n "$WORKLOAD" ] && die "Unexpected argument: $1"
        WORKLOAD="$1"
        shift
        ;;
    esac
  done

  [ -z "$WORKLOAD" ] && die "Usage: atlasctl seed <group>/<app> [--dry-run] [--force]"

  local GROUP="${WORKLOAD%%/*}"
  local APP="${WORKLOAD#*/}"
  [ "$GROUP" = "$APP" ] && die "Invalid format. Use: <group>/<app>"

  local WORKLOAD_DIR="${REPO_ROOT}/workloads/${GROUP}/${APP}"
  local GROUP_SAFE="${GROUP//-/_}"
  local APP_SAFE="${APP//-/_}"
  local PREFIX="VL_${GROUP_SAFE^^}_${APP_SAFE^^}"

  if [ "$FORCE" != "true" ]; then
    [ ! -d "$WORKLOAD_DIR" ] && die "Workload not found: $WORKLOAD_DIR"
    [ ! -f "${WORKLOAD_DIR}/.secret-seed" ] && die ".secret-seed not found at ${WORKLOAD_DIR}/.secret-seed"
    [ ! -f "${WORKLOAD_DIR}/vault/seed-mapping.conf" ] && die "vault/seed-mapping.conf not found"
  fi

  if [ -f "${WORKLOAD_DIR}/.secret-seed" ]; then
    set -a
    # shellcheck disable=SC1090
    source "${WORKLOAD_DIR}/.secret-seed"
    set +a
  fi

  local db_pass_var="${PREFIX}_DB_PASSWORD"
  local s3_key_var="${PREFIX}_S3_ACCESS_KEY"
  local s3_secret_var="${PREFIX}_S3_SECRET_KEY"
  local redis_pass_var="${PREFIX}_REDIS_PASSWORD"

  local DB_PASSWORD="${!db_pass_var:-}"
  local S3_ACCESS_KEY="${!s3_key_var:-}"
  local S3_SECRET_KEY="${!s3_secret_var:-}"
  local REDIS_PASSWORD="${!redis_pass_var:-}"

  if [ "$FORCE" != "true" ]; then
    [ -z "$DB_PASSWORD" ] && die "${db_pass_var} is empty in .secret-seed"
    [ -z "$S3_ACCESS_KEY" ] && die "${s3_key_var} is empty in .secret-seed"
    [ -z "$S3_SECRET_KEY" ] && die "${s3_secret_var} is empty in .secret-seed"
    [ -z "$REDIS_PASSWORD" ] && die "${redis_pass_var} is empty in .secret-seed"
  fi

  local DB_USERNAME="$APP"
  local DB_NAME="$APP"
  local DB_HOST="production-db-rw.database.svc.cluster.local"
  local DB_PORT="5432"
  local S3_ENDPOINT="http://minio.minio.svc.cluster.local:9000"
  local S3_BUCKET="workloads/${GROUP}/${APP}"
  local REDIS_HOST="redis-master.redis.svc.cluster.local"
  local REDIS_PORT="6379"
  local VAULT_PATH="secret/workloads/${GROUP}/${APP}"

  local MINIO_ROOT_USER MINIO_ROOT_PASSWORD PLATFORM_REDIS_PASSWORD
  MINIO_ROOT_USER="$(ksecret minio minio-auth rootUser)"
  MINIO_ROOT_PASSWORD="$(ksecret minio minio-auth rootPassword)"
  PLATFORM_REDIS_PASSWORD="$(ksecret redis redis-auth redis-password)"

  echo "---"
  echo "Seeding workload: ${GROUP}/${APP}"
  echo "  Namespace:      ${GROUP}-${APP}"
  echo "  DB:             ${DB_HOST}/${DB_NAME} (user: ${DB_USERNAME})"
  echo "  S3:             ${S3_ENDPOINT}/${S3_BUCKET}"
  echo "  Redis:          ${REDIS_HOST}:${REDIS_PORT}"
  echo "  Vault:          ${VAULT_PATH}"
  echo "---"

  [ "$DRY_RUN" = "true" ] && { echo ""; echo "DRY RUN — no changes made"; return 0; }

  $SKIP_CONFIRM || prompt_confirm "Seed this workload?" || die "Aborted"

  echo ""
  echo ">> PostgreSQL: creating database and user..."
  local DB_EXISTS
  DB_EXISTS="$(kexec -n database production-db-1 -- psql -t -c "SELECT 1 FROM pg_database WHERE datname='${DB_NAME}'" 2>/dev/null | tr -d ' ')"
  if [ "$DB_EXISTS" = "1" ]; then
    echo "   Database '${DB_NAME}' already exists — skipping CREATE DATABASE"
  else
    kexec -n database production-db-1 -- psql -c "CREATE DATABASE ${DB_NAME};" && echo "   Database '${DB_NAME}' created"
  fi

  local USER_EXISTS
  USER_EXISTS="$(kexec -n database production-db-1 -- psql -t -c "SELECT 1 FROM pg_roles WHERE rolname='${DB_USERNAME}'" 2>/dev/null | tr -d ' ')"
  if [ "$USER_EXISTS" = "1" ]; then
    echo "   User '${DB_USERNAME}' already exists — skipping CREATE USER"
    kexec -n database production-db-1 -- psql -c "ALTER USER ${DB_USERNAME} WITH PASSWORD '${DB_PASSWORD}';" && echo "   User '${DB_USERNAME}' password updated"
  else
    kexec -n database production-db-1 -- psql -c "CREATE USER ${DB_USERNAME} WITH PASSWORD '${DB_PASSWORD}';" && echo "   User '${DB_USERNAME}' created"
  fi
  kexec -n database production-db-1 -- psql -c "GRANT ALL PRIVILEGES ON DATABASE ${DB_NAME} TO ${DB_USERNAME};" && echo "   Privileges granted"
  kexec -n database production-db-1 -- psql -d "${DB_NAME}" -c "GRANT ALL ON SCHEMA public TO ${DB_USERNAME};" && echo "   Schema privileges granted"

  echo ""
  echo ">> MinIO: creating bucket and user..."
  local MINIO_POD
  MINIO_POD="$(kubectl get pod -n minio -l app=minio -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || echo 'minio-0')"
  local MC_ALIAS="atlas-seed"
  kexec -n minio "${MINIO_POD}" -- mc alias set "${MC_ALIAS}" http://localhost:9000 "${MINIO_ROOT_USER}" "${MINIO_ROOT_PASSWORD}"

  local BUCKET_EXISTS
  BUCKET_EXISTS="$(kexec -n minio "${MINIO_POD}" -- mc stat "${MC_ALIAS}/${S3_BUCKET}" 2>&1 || true)"
  if echo "$BUCKET_EXISTS" | grep -q "Object does not exist\|does not exist"; then
    kexec -n minio "${MINIO_POD}" -- mc mb "${MC_ALIAS}/${S3_BUCKET}" && echo "   Bucket '${S3_BUCKET}' created"
  else
    echo "   Bucket '${S3_BUCKET}' already exists — skipping"
  fi

  local MINIO_USER_EXISTS
  MINIO_USER_EXISTS="$(kexec -n minio "${MINIO_POD}" -- mc admin user list "${MC_ALIAS}" 2>/dev/null | grep -c "${S3_ACCESS_KEY}" || true)"
  if [ "$MINIO_USER_EXISTS" -gt 0 ]; then
    echo "   MinIO user '${S3_ACCESS_KEY}' already exists — removing and re-creating"
    kexec -n minio "${MINIO_POD}" -- mc admin user remove "${MC_ALIAS}" "${S3_ACCESS_KEY}"
  fi
  kexec -n minio "${MINIO_POD}" -- mc admin user add "${MC_ALIAS}" "${S3_ACCESS_KEY}" "${S3_SECRET_KEY}" && echo "   MinIO user '${S3_ACCESS_KEY}' created"
  kubectl exec -n minio "${MINIO_POD}" -- mc admin policy set "${MC_ALIAS}" readwrite user="${S3_ACCESS_KEY}" 2>/dev/null || \
  kubectl exec -n minio "${MINIO_POD}" -- mc admin policy attach "${MC_ALIAS}" readwrite --user "${S3_ACCESS_KEY}" 2>/dev/null || true

  echo ""
  echo ">> Vault: writing secrets to ${VAULT_PATH}..."

  local VAULT_DATA
  VAULT_DATA=$(cat <<DATA
db_username=${DB_USERNAME}
db_password=${DB_PASSWORD}
db_host=${DB_HOST}
db_port=${DB_PORT}
db_name=${DB_NAME}
s3_access_key=${S3_ACCESS_KEY}
s3_secret_key=${S3_SECRET_KEY}
s3_endpoint=${S3_ENDPOINT}
s3_bucket=${S3_BUCKET}
redis_password=${PLATFORM_REDIS_PASSWORD}
redis_host=${REDIS_HOST}
redis_port=${REDIS_PORT}
DATA
)

  if [ -f "${WORKLOAD_DIR}/.secret-seed" ]; then
    while IFS='' read -r line; do
      [ -z "$line" ] && continue
      [[ "$line" == \#* ]] && continue
      local line_name="${line%%=*}"
      local line_value="${line#*=}"
      if [[ "$line_name" == ${PREFIX}_* ]]; then
        local suffix="${line_name#${PREFIX}_}"
        case "$suffix" in
          DB_PASSWORD|S3_ACCESS_KEY|S3_SECRET_KEY|REDIS_PASSWORD|PDF_CERT_B64|PDF_KEY_B64) continue ;;
        esac
        VAULT_DATA="${VAULT_DATA}
${suffix,,}=${line_value}"
      fi
    done < "${WORKLOAD_DIR}/.secret-seed"
  fi

  local VAULT_WRITTEN=false
  local VAULT_ROOT_TOKEN
  VAULT_ROOT_TOKEN="$(kubectl get secret -n vault vault-unseal-keys -o jsonpath='{.data.vault-root}' 2>/dev/null | base64 -d || true)"
  if [ -n "$VAULT_ROOT_TOKEN" ]; then
    local VAULT_ARGS=()
    while IFS= read -r line; do
      [ -z "$line" ] && continue
      key="${line%%=*}"
      val="${line#*=}"
      VAULT_ARGS+=("${key}=${val}")
    done <<< "$VAULT_DATA"
    if vault0 kv put "${VAULT_PATH}" "${VAULT_ARGS[@]}"; then
      echo "   Secrets written to ${VAULT_PATH} via vault-0 pod"
      VAULT_WRITTEN=true
    fi
  fi

  if [ "$VAULT_WRITTEN" != "true" ]; then
    if command -v vault &>/dev/null && [ -n "${VAULT_ADDR:-}" ]; then
      vault kv put "${VAULT_PATH}" $VAULT_DATA
      echo "   Secrets written via local vault CLI"
      VAULT_WRITTEN=true
    else
      echo "   WARNING: Vault is not accessible via vault-0 pod or local CLI"
      echo "   Set VAULT_ADDR + VAULT_TOKEN and install vault CLI"
      echo "   Then run: vault kv put ${VAULT_PATH} ${VAULT_DATA//$'\n'/ }"
      echo ""
      echo "   Secrets NOT written to Vault. Continuing with database/bucket only."
    fi
  fi

  echo ""
  echo "=== Seed complete for ${GROUP}/${APP} ==="

  # --- Additional Vault paths from seed-mapping.conf ---
  local SEED_MAPPING="${WORKLOAD_DIR}/vault/seed-mapping.conf"
  if [ "$VAULT_WRITTEN" = "true" ] && [ -f "$SEED_MAPPING" ]; then
    local SEED_TMPDIR
    SEED_TMPDIR="$(mktemp -d)"
    while IFS='' read -r mapping_line; do
      [ -z "$mapping_line" ] && continue
      [[ "$mapping_line" == \#* ]] && continue
      local v_path v_rest v_key v_env
      read -r v_path v_rest <<< "$mapping_line"
      v_path="$(echo "$v_path" | xargs)"
      v_rest="$(echo "$v_rest" | xargs)"
      [ "$v_path" = "$VAULT_PATH" ] && continue
      [ -z "$v_rest" ] && continue
      v_key="${v_rest%%=*}"
      v_env="${v_rest#*=}"
      [ -f "${WORKLOAD_DIR}/.secret-seed" ] || continue
      local v_value
      v_value="$(grep "^${v_env}=" "${WORKLOAD_DIR}/.secret-seed" | tail -1 | cut -d= -f2-)"
      [ -z "$v_value" ] && continue
      if [[ "$v_env" == *_B64 ]]; then
        local path_key
        path_key="$(echo "$v_path" | tr '/' '_')"
        echo "$v_value" | base64 -d > "${SEED_TMPDIR}/${path_key}_${v_key}.pem" 2>/dev/null
        echo "${v_key}=@${SEED_TMPDIR}/${path_key}_${v_key}.pem" >> "${SEED_TMPDIR}/${path_key}.args"
      fi
    done < "$SEED_MAPPING"

    for args_file in "${SEED_TMPDIR}"/*.args; do
      [ -f "$args_file" ] || continue
      local target_path
      target_path="$(basename "$args_file" .args | tr '_' '/')"
      local vault_args=()
      local pod_files=()
      while IFS='=' read -r k eq_val; do
        [ -z "$k" ] && continue
        local val="${eq_val#@}"
        local pod_file
        pod_file="/tmp/$(basename "$val")"
        kubectl exec -i -n vault vault-0 -c vault -- sh -c "cat > ${pod_file}" < "$val" 2>/dev/null
        pod_files+=("$pod_file")
        vault_args+=("${k}=@${pod_file}")
      done < "$args_file"
      if [ ${#vault_args[@]} -gt 0 ]; then
        kubectl exec -n vault vault-0 -c vault -- env VAULT_TOKEN="${VAULT_ROOT_TOKEN}" VAULT_ADDR=http://127.0.0.1:8200 vault kv put "$target_path" "${vault_args[@]}" 2>/dev/null && echo "   Secrets written to ${target_path}"
      fi
      for pf in "${pod_files[@]}"; do
        kubectl exec -n vault vault-0 -c vault -- rm -f "$pf" 2>/dev/null || true
      done
    done
    rm -rf "$SEED_TMPDIR"
  fi

  echo ""
  echo "Next step: atlasctl enable ${GROUP}/${APP} [--sync]"
}

# --- Command: enable ---
cmd_enable() {
  local WORKLOAD=""
  local DRY_RUN=false
  local SYNC=false
  local PUSH=false
  local FORCE=false
  SKIP_CONFIRM=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) DRY_RUN=true; shift ;;
      --sync) SYNC=true; shift ;;
      --push) PUSH=true; shift ;;
      --force) FORCE=true; shift ;;
      --yes|-y) SKIP_CONFIRM=true; shift ;;
      --*|-*) die "Unknown option: $1" ;;
      *)
        [ -n "$WORKLOAD" ] && die "Unexpected argument: $1"
        WORKLOAD="$1"
        shift
        ;;
    esac
  done

  [ -z "$WORKLOAD" ] && die "Usage: atlasctl enable <group>/<app> [--dry-run] [--sync] [--push] [--force] [-y]"

  local GROUP="${WORKLOAD%%/*}"
  local APP="${WORKLOAD#*/}"
  [ "$GROUP" = "$APP" ] && die "Invalid format. Use: <group>/<app>"
  APP_UC="$(echo "$APP" | tr '[:lower:]' '[:upper:]' | tr '-' '_')"
  GROUP_UC="$(echo "$GROUP" | tr '[:lower:]' '[:upper:]' | tr '-' '_')"

  local WORKLOAD_DIR="${REPO_ROOT}/workloads/${GROUP}/${APP}"
  local GITOPS_DIR="${REPO_ROOT}/gitops/workloads/${GROUP}"
  local GITOPS_FILE="${GITOPS_DIR}/${APP}.yaml"
  local GW_FILE="${REPO_ROOT}/gitops/platform-kind/layers/networking/values/gateway-resources/gateway.yaml"
  local GW_ROUTES_DIR="${REPO_ROOT}/gitops/platform-kind/layers/networking/values/gateway-routes"
  local GW_ROUTES_FILE="${GW_ROUTES_DIR}/${APP}.yaml"

  if [ "$FORCE" != "true" ]; then
    [ ! -d "$WORKLOAD_DIR" ] && die "Workload not found: $WORKLOAD_DIR"
    [ ! -f "${WORKLOAD_DIR}/app.yaml" ] && die "app.yaml not found in ${WORKLOAD_DIR}"
    [ -f "$GITOPS_FILE" ] && die "Already enabled at ${GITOPS_FILE} (use --force to overwrite)"
  fi

  if ! command -v yq &>/dev/null; then
    die "yq is required. Install: https://github.com/mikefarah/yq#install"
  fi

  local NAMESPACE
  NAMESPACE="$(yq eval '.spec.destination.namespace' "${WORKLOAD_DIR}/app.yaml" 2>/dev/null || true)"
  [ -z "$NAMESPACE" ] && NAMESPACE="${GROUP}-${APP}"

  local HAS_GATEWAY=false
  [ -f "${WORKLOAD_DIR}/infra/gateway.yaml" ] && HAS_GATEWAY=true

  local REPO_URL
  REPO_URL="$(git -C "${REPO_ROOT}" remote get-url origin 2>/dev/null || echo "https://github.com/aldoshkineg/atlas-idp.git")"
  REPO_URL="${REPO_URL/#git@github.com:/https:\/\/github.com\/}"
  REPO_URL="${REPO_URL%.git}"

  echo "---"
  echo "Enabling workload: ${GROUP}/${APP}"
  echo "  Namespace:      ${NAMESPACE}"
  echo "  GitOps file:    ${GITOPS_FILE}"
  echo "  Gateway patch:  ${HAS_GATEWAY}"
  echo "---"

  local GITOPS_RESOURCES_DIR="${GITOPS_DIR}/${APP}/resources"

  if [ "$DRY_RUN" = "true" ]; then
    echo ""
    echo ">> Would copy ${WORKLOAD_DIR}/app.yaml → ${GITOPS_FILE}"
    echo ">> Would rsync ${WORKLOAD_DIR}/ → ${GITOPS_RESOURCES_DIR}/ (excluding app.yaml, infra/gateway.yaml, .secret-seed, vault, *.tmpl)"

    if [ "$HAS_GATEWAY" = "true" ]; then
      local GW_HOSTNAME
      GW_HOSTNAME="$(yq eval 'select(.kind == "HTTPRoute") | .spec.hostnames[0]' "${WORKLOAD_DIR}/infra/gateway.yaml" 2>/dev/null | head -1 || echo "${APP}.atlas")"
      echo ""
      echo ">> Would copy infra/gateway.yaml → ${GW_ROUTES_FILE}"
      echo ">> Would add listener to: ${GW_FILE}"
      echo "   name: https-${APP}"
      echo "   hostname: ${GW_HOSTNAME}"
      echo "   certificateRefs: [${APP}-cert]"
    fi

    echo ""
    echo "DRY RUN — no changes made"
    $PUSH && echo "(--push ignored in dry-run)"
    $SYNC && echo "(--sync ignored in dry-run)"
    return 0
  fi

  prompt_confirm "Enable this workload?" || die "Aborted"

  mkdir -p "$GITOPS_DIR"
  cp "${WORKLOAD_DIR}/app.yaml" "$GITOPS_FILE"
  echo "  [app] Copied to ${GITOPS_FILE}"

  # rsync all yaml files (excluding app.yaml, infra/gateway.yaml, .secret-seed, vault, tmpl) to resources/
  mkdir -p "$GITOPS_RESOURCES_DIR"
  rsync -a --delete \
    --exclude='app.yaml' \
    --exclude='infra/gateway.yaml' \
    --exclude='.secret-seed' \
    --exclude='vault' \
    --exclude='*.tmpl' \
    "${WORKLOAD_DIR}/" "${GITOPS_RESOURCES_DIR}/"
  echo "  [workload] Synced manifests to ${GITOPS_RESOURCES_DIR}/"

  if [ "$HAS_GATEWAY" = "true" ]; then
    local GW_HOSTNAME
    GW_HOSTNAME="$(yq eval 'select(.kind == "HTTPRoute") | .spec.hostnames[0]' "${WORKLOAD_DIR}/infra/gateway.yaml" 2>/dev/null | head -1 || echo "${APP}.atlas")"

    mkdir -p "$GW_ROUTES_DIR"
    cp "${WORKLOAD_DIR}/infra/gateway.yaml" "$GW_ROUTES_FILE"
    echo "  [gateway-routes] Copied infra/gateway.yaml → ${GW_ROUTES_FILE}"

    local LISTENER_EXISTS
    LISTENER_EXISTS="$(yq eval ".spec.listeners[] | select(.name == \"https-${APP}\")" "$GW_FILE" 2>/dev/null || true)"
    if [ -n "$LISTENER_EXISTS" ]; then
      echo "  [gateway] Listener 'https-${APP}' already exists — skipping"
    else
      local YQ_EXPR
      YQ_EXPR='.spec.listeners += [{"name": "https-'"${APP}"'", "port": 443, "protocol": "HTTPS", "hostname": "'"${GW_HOSTNAME}"'", "allowedRoutes": {"namespaces": {"from": "All"}}, "tls": {"mode": "Terminate", "certificateRefs": [{"name": "'"${APP}"'-cert"}]}}]'
      yq eval -i "$YQ_EXPR" "$GW_FILE"
      echo "  [gateway] Added listener 'https-${APP}' (${GW_HOSTNAME})"
    fi
  fi

  if [ "$SYNC" = "true" ]; then
    git -C "${REPO_ROOT}" add "${GITOPS_FILE}"
    git -C "${REPO_ROOT}" add "${GITOPS_RESOURCES_DIR}"
    if [ "$HAS_GATEWAY" = "true" ]; then
      git -C "${REPO_ROOT}" add "$GW_FILE"
      git -C "${REPO_ROOT}" add "$GW_ROUTES_FILE"
    fi
    git -C "${REPO_ROOT}" commit -m "enable(workloads): promote ${GROUP}/${APP}" || echo "   (nothing to commit)"

    if [ "$PUSH" = "true" ]; then
      git -C "${REPO_ROOT}" push
      echo "  [push] Changes pushed"

      if command -v argocd &>/dev/null; then
        echo "  [argocd] Syncing root-app..."
        argocd app sync root-app --timeout 120 2>/dev/null || true
        echo "  [argocd] Waiting for ${GROUP}-${APP}..."
        for _ in $(seq 1 30); do
          local ARGO_STATUS
          ARGO_STATUS="$(argocd app get "${GROUP}-${APP}" -o json 2>/dev/null | yq eval '.status.sync.status' - 2>/dev/null || echo "")"
          if [ "$ARGO_STATUS" = "Synced" ]; then
            echo "  [argocd] ${GROUP}-${APP} is Synced"
            break
          fi
          sleep 2
        done
      else
        echo "  (install argocd CLI to auto-sync after push)"
      fi
    else
      echo "  (use --push to push commits)"
    fi
  fi

  echo ""
  echo "=== Enable complete for ${GROUP}/${APP} ==="
  echo ""
  echo "Next step: atlasctl status ${GROUP}/${APP}"
}

# --- Command: disable ---
cmd_disable() {
  local WORKLOAD=""
  local DRY_RUN=false
  local SYNC=false
  local PUSH=false
  SKIP_CONFIRM=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) DRY_RUN=true; shift ;;
      --sync) SYNC=true; shift ;;
      --push) PUSH=true; shift ;;
      --keep-workload) echo "  (--keep-workload is now default, ignored)" ; shift ;;
      --yes|-y) SKIP_CONFIRM=true; shift ;;
      --*|-*) die "Unknown option: $1" ;;
      *)
        [ -n "$WORKLOAD" ] && die "Unexpected argument: $1"
        WORKLOAD="$1"
        shift
        ;;
    esac
  done

  [ -z "$WORKLOAD" ] && die "Usage: atlasctl disable <group>/<app> [--dry-run] [--sync] [--push] [-y]"

  local GROUP="${WORKLOAD%%/*}"
  local APP="${WORKLOAD#*/}"
  [ "$GROUP" = "$APP" ] && die "Invalid format. Use: <group>/<app>"

  local WORKLOAD_DIR="${REPO_ROOT}/workloads/${GROUP}/${APP}"
  local GITOPS_DIR="${REPO_ROOT}/gitops/workloads/${GROUP}"
  local GITOPS_FILE="${GITOPS_DIR}/${APP}.yaml"
  local GITOPS_RESOURCES_DIR="${GITOPS_DIR}/${APP}/resources"
  local GITOPS_WORKLOAD_DIR="${GITOPS_DIR}/${APP}"
  local GW_FILE="${REPO_ROOT}/gitops/platform-kind/layers/networking/values/gateway-resources/gateway.yaml"
  local GW_ROUTES_DIR="${REPO_ROOT}/gitops/platform-kind/layers/networking/values/gateway-routes"
  local GW_ROUTES_FILE="${GW_ROUTES_DIR}/${APP}.yaml"

  [ ! -f "$GITOPS_FILE" ] && die "Not enabled — ${GITOPS_FILE} does not exist"

  if ! command -v yq &>/dev/null; then
    die "yq is required. Install: https://github.com/mikefarah/yq#install"
  fi

  local HAS_GATEWAY=false
  [ -f "${WORKLOAD_DIR}/infra/gateway.yaml" ] && HAS_GATEWAY=true

  echo "---"
  echo "Disabling workload: ${GROUP}/${APP}"
  echo "  GitOps file:    ${GITOPS_FILE} (remove)"
  echo "  Workload dir:   ${WORKLOAD_DIR} (kept)"
  echo "  Gateway patch:  ${HAS_GATEWAY}"
  echo "---"

  if [ "$DRY_RUN" = "true" ]; then
    echo ""
    echo ">> Would remove listener from: ${GW_FILE}"
    echo "   name: https-${APP}"
    echo ""
    echo ">> Would delete: ${GITOPS_FILE}"
    if [ -d "$GITOPS_RESOURCES_DIR" ]; then
      echo ">> Would delete directory: ${GITOPS_RESOURCES_DIR}/"
    fi
    if [ -f "$GW_ROUTES_FILE" ]; then
      echo ">> Would delete: ${GW_ROUTES_FILE}"
    fi
    if [ -d "$GITOPS_DIR" ] && [ -z "$(ls -A "$GITOPS_DIR" 2>/dev/null)" ]; then
      echo ">> Would remove empty: ${GITOPS_DIR}"
    fi
    echo ""
    echo "DRY RUN — no changes made"
    $PUSH && echo "(--push ignored in dry-run)"
    $SYNC && echo "(--sync ignored in dry-run)"
    return 0
  fi

  prompt_confirm "Disable this workload?" || die "Aborted"

  local LISTENER_EXISTS
  LISTENER_EXISTS="$(yq eval ".spec.listeners[] | select(.name == \"https-${APP}\")" "$GW_FILE" 2>/dev/null || true)"
  if [ -n "$LISTENER_EXISTS" ]; then
    yq eval -i "del(.spec.listeners[] | select(.name == \"https-${APP}\"))" "$GW_FILE"
    echo "  [gateway] Removed listener 'https-${APP}'"
  else
    echo "  [gateway] Listener 'https-${APP}' not found — skipping"
  fi

  rm -f "$GITOPS_FILE"
  echo "  [gitops] Removed ${GITOPS_FILE}"

  if [ -d "$GITOPS_RESOURCES_DIR" ]; then
    rm -rf "$GITOPS_RESOURCES_DIR"
    echo "  [gitops] Removed directory ${GITOPS_RESOURCES_DIR}/"
  fi

  if [ -d "$GITOPS_WORKLOAD_DIR" ] && [ -z "$(ls -A "$GITOPS_WORKLOAD_DIR" 2>/dev/null)" ]; then
    rmdir "$GITOPS_WORKLOAD_DIR"
    echo "  [gitops] Removed empty directory ${GITOPS_WORKLOAD_DIR}/"
  fi

  if [ -f "$GW_ROUTES_FILE" ]; then
    rm -f "$GW_ROUTES_FILE"
    echo "  [gateway-routes] Removed ${GW_ROUTES_FILE}"
  fi

  if [ -d "$GITOPS_DIR" ] && [ -z "$(ls -A "$GITOPS_DIR" 2>/dev/null)" ]; then
    rmdir "$GITOPS_DIR"
    echo "  [gitops] Removed empty directory ${GITOPS_DIR}"
  fi

  if [ "$SYNC" = "true" ]; then
    git -C "${REPO_ROOT}" add "$GITOPS_FILE" 2>/dev/null || true
    git -C "${REPO_ROOT}" add "$GITOPS_RESOURCES_DIR" 2>/dev/null || true
    git -C "${REPO_ROOT}" add "$GITOPS_WORKLOAD_DIR" 2>/dev/null || true
    git -C "${REPO_ROOT}" add "$GW_FILE"
    git -C "${REPO_ROOT}" add "$GW_ROUTES_FILE" 2>/dev/null || true
    git -C "${REPO_ROOT}" commit -m "disable(workloads): remove ${GROUP}/${APP}" || echo "   (nothing to commit)"

    if [ "$PUSH" = "true" ]; then
      git -C "${REPO_ROOT}" push
      echo "  [push] Changes pushed"

      kubectl patch application "${GROUP}-${APP}" -n argocd -p \
        '{"metadata":{"finalizers":["resources-finalizer.argocd.argoproj.io"]}}' --type=merge 2>/dev/null || true
      kubectl delete application "${GROUP}-${APP}" -n argocd --wait=false 2>/dev/null || \
        echo "  [kubectl] Application already pruned by ArgoCD"
    else
      echo "  (use --push to push commits)"
    fi
  fi

  echo ""
  echo "=== Disable complete for ${GROUP}/${APP} ==="
}

# --- Command: delete ---
cmd_delete() {
  local WORKLOAD=""
  local DRY_RUN=false
  SKIP_CONFIRM=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) DRY_RUN=true; shift ;;
      --yes|-y) SKIP_CONFIRM=true; shift ;;
      --*|-*) die "Unknown option: $1" ;;
      *)
        [ -n "$WORKLOAD" ] && die "Unexpected argument: $1"
        WORKLOAD="$1"
        shift
        ;;
    esac
  done

  [ -z "$WORKLOAD" ] && die "Usage: atlasctl delete <group>/<app> [--dry-run] [-y]"

  local GROUP="${WORKLOAD%%/*}"
  local APP="${WORKLOAD#*/}"
  [ "$GROUP" = "$APP" ] && die "Invalid format. Use: <group>/<app>"

  local WORKLOAD_DIR="${REPO_ROOT}/workloads/${GROUP}/${APP}"
  local GITOPS_FILE="${REPO_ROOT}/gitops/workloads/${GROUP}/${APP}.yaml"

  [ ! -d "$WORKLOAD_DIR" ] && die "Workload not found: ${WORKLOAD_DIR}"

