#!/usr/bin/env bash
set -euo pipefail

# atlasctl — Atlas IDP workload management CLI
# Usage:
#   atlasctl new <app> --group <group> --repo <url> [options]
#   atlasctl seed <group>/<app>
#   atlasctl list

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
TEMPLATES_DIR="${REPO_ROOT}/templates/gold"

usage() {
  cat <<USAGE
atlasctl — Atlas IDP workload management

Commands:
  new       Scaffold a new workload structure
  seed      Provision DB + bucket + write secrets to Vault
  list      List all workloads

atlasctl new <app> --group <group> --repo <url> [options]
  Required:
    --group <group>    Team/group name (e.g., aldoshkineg)
    --repo <url>       Application repository URL

  Options:
    --namespace <ns>   Kubernetes namespace (default: <group>-<app>)
    --repo-path <p>    Path within repo for manifests (default: .)
    --helm             Use Helm chart
    --helm-values <s>  Inline Helm values string or file path
    --secrets          Create vault/ + secrets.yaml (DB + S3 + Redis)
    --ingress          Create gateway.yaml (HTTPRoute + Certificate)
    --monitoring       Create PodMonitor + PrometheusRule
    --keda             Create autoscaling/scaled-object.yaml
    --rollouts         Create rollouts/rollout.yaml
    --sa <sas>         Service accounts for Vault auth (comma-sep, default: <app>)
    --yes, -y          Skip confirmation prompt

Examples:
  atlasctl new seal --group aldoshkineg --repo https://github.com/aldoshkineg/atlas-idp-seal.git --repo-path charts/seal --helm --secrets --ingress --monitoring
USAGE
}

die() { echo "Error: $*" >&2; exit 1; }

# --- Rendering ---
render_template() {
  local src="$1" dst="$2"
  local content
  content="$(< "$src")"

  content="${content//"{{APP}}"/$APP}"
  content="${content//"{{APP_UC}}"/$APP_UC}"
  content="${content//"{{GROUP}}"/$GROUP}"
  content="${content//"{{GROUP_UC}}"/$GROUP_UC}"
  content="${content//"{{NAMESPACE}}"/$NAMESPACE}"
  content="${content//"{{REPO_URL}}"/$REPO_URL}"
  content="${content//"{{REPO_PATH}}"/$REPO_PATH}"

  if [ -n "${HOSTNAME:-}" ]; then
    content="${content//"{{HOSTNAME}}"/$HOSTNAME}"
  fi

  if [ "$HELM" = "true" ]; then
    local helm_block=$'helm:\n      values: |\n'"$HELM_VALUES_INDENTED"
    content="${content//"{{REPO_HELM_SETTINGS}}"/$helm_block}"
  else
    content="${content//"{{REPO_HELM_SETTINGS}}"/}"
  fi

  # Replace remaining {{SERVICE_ACCOUNTS}} after rendering (for k8s-auth-role)
  if [ -n "${SERVICE_ACCOUNTS:-}" ]; then
    content="${content//"{{SERVICE_ACCOUNTS}}"/$SERVICE_ACCOUNTS}"
  fi

  echo "$content" > "$dst"
}

prompt_confirm() {
  local msg="$1"
  if [ "${SKIP_CONFIRM:-false}" = "true" ]; then
    return 0
  fi
  read -r -p "$msg [y/N] " reply
  case "$reply" in
    [yY]|[yY][eE][sS]) return 0 ;;
    *) return 1 ;;
  esac
}

# --- Command: new ---
cmd_new() {
  APP=""
  GROUP=""
  REPO_URL=""
  NAMESPACE=""
  REPO_PATH="."
  HELM=false
  HELM_VALUES=""
  WITH_SECRETS=false
  WITH_INGRESS=false
  WITH_MONITORING=false
  WITH_KEDA=false
  WITH_ROLLOUTS=false
  SERVICE_ACCOUNTS=""
  SKIP_CONFIRM=false
  HOSTNAME=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --group) GROUP="$2"; shift 2 ;;
      --repo) REPO_URL="$2"; shift 2 ;;
      --namespace) NAMESPACE="$2"; shift 2 ;;
      --repo-path) REPO_PATH="$2"; shift 2 ;;
      --helm) HELM=true; shift ;;
      --helm-values) HELM_VALUES="$2"; shift 2 ;;
      --secrets) WITH_SECRETS=true; shift ;;
      --ingress) WITH_INGRESS=true; shift ;;
      --monitoring) WITH_MONITORING=true; shift ;;
      --keda) WITH_KEDA=true; shift ;;
      --rollouts) WITH_ROLLOUTS=true; shift ;;
      --sa) SERVICE_ACCOUNTS="$2"; shift 2 ;;
      --yes|-y) SKIP_CONFIRM=true; shift ;;
      -*|--*) die "Unknown option: $1" ;;
      *)
        [ -n "$APP" ] && die "Unexpected argument: $1"
        APP="$1"
        shift
        ;;
    esac
  done

  [ -z "$APP" ] && die "App name is required"
  [ -z "$GROUP" ] && die "--group is required"
  [ -z "$REPO_URL" ] && die "--repo is required"

  APP_UC="$(echo "$APP" | tr '[:lower:]' '[:upper:]')"
  GROUP_UC="$(echo "$GROUP" | tr '[:lower:]' '[:upper:]')"
  [ -z "$NAMESPACE" ] && NAMESPACE="${GROUP}-${APP}"
  [ -z "$SERVICE_ACCOUNTS" ] && SERVICE_ACCOUNTS="$APP"

  local WORKLOAD_DIR="${REPO_ROOT}/workloads/${GROUP}/${APP}"

  if [ -d "$WORKLOAD_DIR" ]; then
    die "Workload already exists: $WORKLOAD_DIR"
  fi

  # Prepare Helm values
  local HELM_VALUES_INDENTED=""
  if [ "$HELM" = "true" ] && [ -n "$HELM_VALUES" ]; then
    if [ -f "$HELM_VALUES" ]; then
      HELM_VALUES_INDENTED="$(sed 's/^/        /' "$HELM_VALUES")"
    else
      HELM_VALUES_INDENTED="$(echo "$HELM_VALUES" | sed 's/^/        /')"
    fi
  fi

  # Default hostname for ingress
  HOSTNAME="${APP}.atlas"

  # Collect features string for display
  local FEATURES=""
  $WITH_SECRETS && FEATURES+="secrets "
  $WITH_INGRESS && FEATURES+="ingress "
  $WITH_MONITORING && FEATURES+="monitoring "
  $WITH_KEDA && FEATURES+="keda "
  $WITH_ROLLOUTS && FEATURES+="rollouts "

  echo "---"
  echo "Scaffolding new workload:"
  echo "  App:       $APP"
  echo "  Group:     $GROUP"
  echo "  Namespace: $NAMESPACE"
  echo "  Repo:      $REPO_URL (path: $REPO_PATH)"
  echo "  Features:  ${FEATURES:-none}"
  echo "---"

  prompt_confirm "Create workload?" || die "Aborted"

  mkdir -p "$WORKLOAD_DIR"

  # --- Always: app.yaml ---
  render_template "${TEMPLATES_DIR}/app.yaml.tmpl" "${WORKLOAD_DIR}/app.yaml"
  echo "  [app.yaml] Created"

  # --- With --secrets: vault/ + secrets.yaml + .secret-seed ---
  if [ "$WITH_SECRETS" = "true" ]; then
    mkdir -p "${WORKLOAD_DIR}/vault"

    render_template "${TEMPLATES_DIR}/vault/policy.hcl.tmpl" "${WORKLOAD_DIR}/vault/policy.hcl"
    render_template "${TEMPLATES_DIR}/vault/k8s-auth-role.yaml.tmpl" "${WORKLOAD_DIR}/vault/k8s-auth-role.yaml"
    render_template "${TEMPLATES_DIR}/vault/seed-mapping.conf.tmpl" "${WORKLOAD_DIR}/vault/seed-mapping.conf"

    render_template "${TEMPLATES_DIR}/secrets.yaml.tmpl" "${WORKLOAD_DIR}/secrets.yaml"

    # Generate .secret-seed with random passwords
    local DB_PASS S3_ACCESS S3_SECRET REDIS_PASS
    DB_PASS=$(openssl rand -base64 24 2>/dev/null || echo "changeme")
    S3_ACCESS=$(openssl rand -hex 16 2>/dev/null || echo "changeme")
    S3_SECRET=$(openssl rand -base64 32 2>/dev/null || echo "changeme")
    REDIS_PASS=$(openssl rand -base64 24 2>/dev/null || echo "changeme")

    cat > "${WORKLOAD_DIR}/.secret-seed" <<EOF
# ${GROUP}/${APP} — atlasctl seed environment file
# Auto-generated by atlasctl new. Edit values before running atlasctl seed.
#
# Format: KEY=value
VL_${GROUP_UC}_${APP_UC}_DB_PASSWORD=${DB_PASS}
VL_${GROUP_UC}_${APP_UC}_S3_ACCESS_KEY=${S3_ACCESS}
VL_${GROUP_UC}_${APP_UC}_S3_SECRET_KEY=${S3_SECRET}
VL_${GROUP_UC}_${APP_UC}_REDIS_PASSWORD=${REDIS_PASS}
EOF

    echo "  [secrets] Created vault/ + secrets.yaml + .secret-seed"
  fi

  # --- With --ingress: gateway.yaml ---
  if [ "$WITH_INGRESS" = "true" ]; then
    render_template "${TEMPLATES_DIR}/gateway.yaml.tmpl" "${WORKLOAD_DIR}/gateway.yaml"
    echo "  [gateway] Created gateway.yaml (HTTPRoute + Certificate)"
  fi

  # --- With --monitoring: monitoring/ ---
  if [ "$WITH_MONITORING" = "true" ]; then
    mkdir -p "${WORKLOAD_DIR}/monitoring"
    render_template "${TEMPLATES_DIR}/monitoring/pod-monitor.yaml.tmpl" "${WORKLOAD_DIR}/monitoring/pod-monitor.yaml"
    render_template "${TEMPLATES_DIR}/monitoring/prometheus-rule.yaml.tmpl" "${WORKLOAD_DIR}/monitoring/prometheus-rule.yaml"
    echo "  [monitoring] Created PodMonitor + PrometheusRule"
  fi

  # --- With --keda: autoscaling/ ---
  if [ "$WITH_KEDA" = "true" ]; then
    mkdir -p "${WORKLOAD_DIR}/autoscaling"
    # TODO: create scaled-object.yaml.tmpl
    echo "  [keda] Created autoscaling/ (template pending)"
  fi

  # --- With --rollouts: rollouts/ ---
  if [ "$WITH_ROLLOUTS" = "true" ]; then
    mkdir -p "${WORKLOAD_DIR}/rollouts"
    # TODO: create rollout.yaml.tmpl
    echo "  [rollouts] Created rollouts/ (template pending)"
  fi

  echo ""
  echo "=== Workload ${GROUP}/${APP} scaffolded ==="
  echo ""
  echo "Next steps:"
  echo "  1. Review and customize files in workloads/${GROUP}/${APP}/"
  echo "  2. Edit .secret-seed if needed (passwords already generated)"
  if [ "$WITH_SECRETS" = "true" ]; then
    echo "  3. Run: atlasctl seed ${GROUP}/${APP}"
  fi
  echo "  4. Run: atlasctl enable ${GROUP}/${APP} [--sync]"
}

# --- Command: seed ---
cmd_seed() {
  echo "TODO: atlasctl seed — provisioning DB + bucket + Vault"
  echo "Usage: atlasctl seed <group>/<app>"
  exit 1
}

# --- Command: list ---
cmd_list() {
  if [ ! -d "${REPO_ROOT}/workloads" ]; then
    echo "No workloads found"
    exit 0
  fi

  echo "Workloads:"
  for group_dir in "${REPO_ROOT}/workloads"/*/; do
    [ ! -d "$group_dir" ] && continue
    local group
    group="$(basename "$group_dir")"
    for app_dir in "$group_dir"*/; do
      [ ! -d "$app_dir" ] && continue
      local app
      app="$(basename "$app_dir")"
      local features=""
      [ -f "${app_dir}.secret-seed" ] && features+="secrets "
      [ -f "${app_dir}gateway.yaml" ] && features+="gateway "
      [ -f "${app_dir}monitoring/prometheus-rule.yaml" ] && features+="monitoring "
      [ -d "${app_dir}autoscaling" ] && features+="keda "
      [ -d "${app_dir}rollouts" ] && features+="rollouts "
      [ -z "$features" ] && features="(no features)"
      echo "  ${group}/${app}  [${features}]"
    done
  done
}

# --- Main ---
[ $# -eq 0 ] && { usage; exit 1; }

CMD="$1"
shift

case "$CMD" in
  new) cmd_new "$@" ;;
  seed) cmd_seed "$@" ;;
  list) cmd_list "$@" ;;
  enable|disable|status)
    echo "TODO: atlasctl $CMD — not yet implemented"
    exit 1
    ;;
  -h|--help) usage ;;
  *) die "Unknown command: $CMD (use --help for usage)" ;;
esac
