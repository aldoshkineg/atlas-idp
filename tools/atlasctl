  echo "=== Delete complete for ${GROUP}/${APP} ==="
}

# --- Command: status ---
cmd_status() {
  local WORKLOAD=""
  local JSON=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --json) JSON=true; shift ;;
      --*|-*) die "Unknown option: $1" ;;
      *)
        [ -n "$WORKLOAD" ] && die "Unexpected argument: $1"
        WORKLOAD="$1"
        shift
        ;;
    esac
  done

  [ -z "$WORKLOAD" ] && die "Usage: atlasctl status <group>/<app> [--json]"

  local GROUP="${WORKLOAD%%/*}"
  local APP="${WORKLOAD#*/}"
  [ "$GROUP" = "$APP" ] && die "Invalid format. Use: <group>/<app>"

  local WORKLOAD_DIR="${REPO_ROOT}/workloads/${GROUP}/${APP}"
  local GITOPS_FILE="${REPO_ROOT}/gitops/workloads/${GROUP}/${APP}.yaml"
  local GW_FILE="${REPO_ROOT}/gitops/platform-kind/layers/networking/values/gateway-resources/gateway.yaml"

  [ ! -d "$WORKLOAD_DIR" ] && die "Workload not found: ${WORKLOAD_DIR}"

  # --- Gather data ---
  local NAMESPACE=""
  [ -f "${WORKLOAD_DIR}/app.yaml" ] && NAMESPACE="$(yq eval '.spec.destination.namespace' "${WORKLOAD_DIR}/app.yaml" 2>/dev/null || true)"
  [ -z "$NAMESPACE" ] && NAMESPACE="${GROUP}-${APP}"

  local FEATURES
  FEATURES="$(detect_features "${WORKLOAD_DIR}/")"
  [ -z "$FEATURES" ] && FEATURES="none"

  local ENABLED=false
  [ -f "$GITOPS_FILE" ] && ENABLED=true

  local GW_LISTENER=false
  if [ -f "$GW_FILE" ] && command -v yq &>/dev/null; then
    local CHECK
    CHECK="$(yq eval ".spec.listeners[] | select(.name == \"https-${APP}\")" "$GW_FILE" 2>/dev/null || true)"
    [ -n "$CHECK" ] && GW_LISTENER=true
  fi

  local ARGOCD_SYNC=""
  if command -v argocd &>/dev/null; then
    ARGOCD_SYNC="$(argocd app get "${GROUP}-${APP}" -o json 2>/dev/null | yq eval '.status.sync.status' - 2>/dev/null || echo "")"
  fi

  # --- Output ---
  if [ "$JSON" = "true" ]; then
    cat <<JSON
{
  "name": "${GROUP}/${APP}",
  "namespace": "${NAMESPACE}",
      "features": [$(echo "$FEATURES" | xargs | sed 's/ /", "/g' | sed 's/^/"/;s/$/"/')],
  "enabled": ${ENABLED},
  "gateway_listener": ${GW_LISTENER},
  "argocd_sync": $( [ -n "$ARGOCD_SYNC" ] && echo "\"${ARGOCD_SYNC}\"" || echo null )
}
JSON
  else
    echo "=== ${GROUP}/${APP} ==="
    echo "  Namespace:      ${NAMESPACE}"
    echo "  Features:       ${FEATURES}"
    if [ "$ENABLED" = "true" ]; then
      echo "  Enabled:        $(green "yes")"
    else
      echo "  Enabled:        $(yellow "no")"
    fi
    if [ "$GW_LISTENER" = "true" ]; then
      echo "  Gateway:        $(green "yes")"
    else
      echo "  Gateway:        $(yellow "no")"
    fi
    if [ -n "$ARGOCD_SYNC" ]; then
      case "$ARGOCD_SYNC" in
        Synced)    echo "  ArgoCD Sync:    $(green "${ARGOCD_SYNC}")" ;;
        OutOfSync) echo "  ArgoCD Sync:    $(red "${ARGOCD_SYNC}")" ;;
        *)         echo "  ArgoCD Sync:    ${ARGOCD_SYNC}" ;;
      esac
    fi
  fi
}

# --- Command: list ---
cmd_list() {
  local JSON=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --json) JSON=true; shift ;;
      --*|-*) die "Unknown option: $1" ;;
      *) die "Unexpected argument: $1" ;;
    esac
  done

  if [ ! -d "${REPO_ROOT}/workloads" ]; then
    if [ "$JSON" = "true" ]; then
      echo "[]"
    else
      echo "No workloads found"
    fi
    exit 0
  fi

  local GW_FILE="${REPO_ROOT}/gitops/platform-kind/layers/networking/values/gateway-resources/gateway.yaml"
  local FIRST=true

  if [ "$JSON" = "true" ]; then
    echo "["
  else
    echo "Workloads:"
  fi

  for group_dir in "${REPO_ROOT}/workloads"/*/; do
    [ ! -d "$group_dir" ] && continue
    local group
    group="$(basename "$group_dir")"
    for app_dir in "$group_dir"*/; do
      [ ! -d "$app_dir" ] && continue
      [ ! -f "${app_dir}app.yaml" ] && continue
      local app
      app="$(basename "$app_dir")"

      local features
      features="$(detect_features "$app_dir")"
      [ -z "$features" ] && features="none"

      local enabled=false
      [ -f "${REPO_ROOT}/gitops/workloads/${group}/${app}.yaml" ] && enabled=true

      local gw_listener=false
      if [ -f "$GW_FILE" ] && command -v yq &>/dev/null; then
        local CHECK
        CHECK="$(yq eval ".spec.listeners[] | select(.name == \"https-${app}\")" "$GW_FILE" 2>/dev/null || true)"
        [ -n "$CHECK" ] && gw_listener=true
      fi

      if [ "$JSON" = "true" ]; then
        $FIRST || echo ","
        FIRST=false
        cat <<JSON
    {
      "name": "${group}/${app}",
      "features": [$(echo "$features" | xargs | sed 's/ /", "/g' | sed 's/^/"/;s/$/"/')],
      "enabled": ${enabled},
      "gateway_listener": ${gw_listener}
    }
JSON
      else
        local status_icon
        if [ "$enabled" = "true" ]; then
          status_icon="$(green "✓")"
        else
          status_icon="$(yellow "○")"
        fi
        echo "  ${status_icon} ${group}/${app}  [${features}]"
      fi
    done
  done

  if [ "$JSON" = "true" ]; then
    echo "]"
  fi
}

# --- Main ---
[ $# -eq 0 ] && { usage; exit 1; }

CMD="$1"
shift

case "$CMD" in
  new) cmd_new "$@" ;;
  seed) cmd_seed "$@" ;;
  enable) cmd_enable "$@" ;;
  disable) cmd_disable "$@" ;;
  delete) cmd_delete "$@" ;;
  status) cmd_status "$@" ;;
  list) cmd_list "$@" ;;
  -h|--help) usage ;;
  *) die "Unknown command: $CMD (use --help for usage)" ;;
esac
