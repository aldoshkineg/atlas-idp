# Terraform / OpenTofu
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
#.terraform.lock.hcl
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Kubernetes / kind
kubeconfig
*.kubeconfig
kind-export/

# Secrets (local files, stay in repo tree)
.env
.env.*
!.env.example
*.pem
*.key

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store

# Build artifacts
dist/
target/
__pycache__/
*.pyc
node_modules/

# Trivy cache
.trivycache/

# Local overrides
*.local.yaml
*.local.yml

# GitHub Actions Runner
tools/ci/local-runner/runner-data
tools/ci/local-runner/.env
tools/ci/local-runner/terraform-cache

# Act runner cache
tools/ci/act-runner/cache/*
!tools/ci/act-runner/cache/.gitkeep

# Act secrets
.secrets
.aider*
.continue

# Workload auto-generated secrets (local, rsync excludes from gitops)
.secret-seed

# Sealed Secrets pre-generated key (for reproducible encryption)
.sealed-keys/

# Self-signed CA
security/certs/ca*

# Dev certs
.certs/

apps/seal/tests/load/reports
