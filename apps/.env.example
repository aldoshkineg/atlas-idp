# text2pdf — Local Development
# Copy to .env and adjust as needed.
# DO NOT commit .env to version control.
#
# Backend API reads: POSTGRES_*, REDIS_*, HTTP_PORT, LOG_LEVEL,
#                     MINIO_ENDPOINT, DOWNLOAD_URL_PREFIX, OTEL_EXPORTER_OTLP_ENDPOINT
# Worker reads: REDIS_*, MINIO_*, SIGN_CERT_PATH, SIGN_KEY_PATH,
#               WORKER_POLL_INTERVAL_MS, OTEL_EXPORTER_OTLP_ENDPOINT

# --- Shared ---

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4318

# --- Backend API only ---

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=text2pdf
POSTGRES_PASSWORD=text2pdf
POSTGRES_DB=text2pdf

# HTTP
HTTP_PORT=8080
LOG_LEVEL=info

# MinIO endpoint for PG download URL construction (no MinIO client in backend)
MINIO_ENDPOINT=localhost:9000
DOWNLOAD_URL_PREFIX=http://localhost:9000

# --- Worker only ---

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadminpassword
MINIO_USE_SSL=false

# PDF signing certs (dev: gen-certs; prod: Vault Agent)
SIGN_CERT_PATH=.certs/tls.crt
SIGN_KEY_PATH=.certs/tls.key

# Worker loop
WORKER_POLL_INTERVAL_MS=1000