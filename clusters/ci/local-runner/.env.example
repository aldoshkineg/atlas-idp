# GitHub Actions Runner Environment Variables
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control

# GitHub Runner Registration Token (get it from: ./setup-runner.sh <your-github-pat>)
# This token is short-lived and should be regenerated for each runner setup
RUNNER_TOKEN=your-runner-registration-token-here

# Optional: Runner configuration
# RUNNER_NAME=atlas-idp-docker-runner
# LABELS=self-hosted,docker,linux
# RUNNER_SCOPE=repo
