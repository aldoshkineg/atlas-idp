apiVersion: postgresql.cnpg.io/v1
kind: Cluster
metadata:
  name: {{APP}}-db
  namespace: {{NAMESPACE}}
  labels:
    app.kubernetes.io/component: database
    app.kubernetes.io/part-of: {{APP}}
spec:
  instances: 1
  imageName: ghcr.io/cloudnative-pg/postgresql:17.6
  primaryUpdateStrategy: unsupervised
  storage:
    size: 256Mi
    storageClass: csi-hostpath-sc
  resources:
    requests:
      memory: 256Mi
      cpu: 100m
    limits:
      memory: 512Mi
      cpu: 500m
  monitoring:
    enablePodMonitor: false
  postgresql:
    parameters:
      max_connections: "100"
      shared_buffers: "64MB"
  bootstrap:
    initdb:
      database: {{APP}}
      owner: {{APP}}
  plugins:
    - name: barman-cloud.cloudnative-pg.io
      enabled: true
      isWALArchiver: true
      parameters:
        barmanObjectName: {{APP}}-db-backup