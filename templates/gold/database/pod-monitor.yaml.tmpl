apiVersion: monitoring.coreos.com/v1
kind: PodMonitor
metadata:
  name: {{APP}}-db
  namespace: {{NAMESPACE}}
spec:
  selector:
    matchLabels:
      cnpg.io/cluster: {{APP}}-db
  podMetricsEndpoints:
    - port: metrics
      interval: 30s
      scrapeTimeout: 10s
  namespaceSelector:
    matchNames:
      - {{NAMESPACE}}