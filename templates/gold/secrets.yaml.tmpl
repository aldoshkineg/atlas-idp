---
# Database credentials — shared production-db (CNPG)
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: {{APP}}-db
  namespace: {{NAMESPACE}}
  annotations:
    argocd.argoproj.io/sync-wave: "100"
spec:
  refreshInterval: 1m
  secretStoreRef:
    name: vault
    kind: ClusterSecretStore
  target:
    name: {{APP}}-db
  data:
    - secretKey: username
      remoteRef:
        key: secret/workloads/{{GROUP}}/{{APP}}
        property: db_username
    - secretKey: password
      remoteRef:
        key: secret/workloads/{{GROUP}}/{{APP}}
        property: db_password
    - secretKey: host
      remoteRef:
        key: secret/workloads/{{GROUP}}/{{APP}}
        property: db_host
    - secretKey: port
      remoteRef:
        key: secret/workloads/{{GROUP}}/{{APP}}
        property: db_port
    - secretKey: dbname
      remoteRef:
        key: secret/workloads/{{GROUP}}/{{APP}}
        property: db_name
---
# S3 credentials — shared MinIO
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: {{APP}}-s3
  namespace: {{NAMESPACE}}
  annotations:
    argocd.argoproj.io/sync-wave: "100"
spec:
  refreshInterval: 1m
  secretStoreRef:
    name: vault
    kind: ClusterSecretStore
  target:
    name: {{APP}}-s3
  data:
    - secretKey: accessKey
      remoteRef:
        key: secret/workloads/{{GROUP}}/{{APP}}
        property: s3_access_key
    - secretKey: secretKey
      remoteRef:
        key: secret/workloads/{{GROUP}}/{{APP}}
        property: s3_secret_key
    - secretKey: endpoint
      remoteRef:
        key: secret/workloads/{{GROUP}}/{{APP}}
        property: s3_endpoint
    - secretKey: bucket
      remoteRef:
        key: secret/workloads/{{GROUP}}/{{APP}}
        property: s3_bucket
