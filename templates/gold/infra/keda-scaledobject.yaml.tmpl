apiVersion: keda.sh/v1alpha1
kind: TriggerAuthentication
metadata:
  name: {{APP}}-keda-redis-auth
  namespace: {{NAMESPACE}}
  annotations:
    argocd.argoproj.io/sync-wave: "135"
spec:
  secretTargetRef:
    - parameter: password
      name: {{APP}}-worker-secret
      key: REDIS_PASSWORD
---
apiVersion: keda.sh/v1alpha1
kind: ScaledObject
metadata:
  name: {{APP}}-worker
  namespace: {{NAMESPACE}}
  annotations:
    argocd.argoproj.io/sync-wave: "136"
spec:
  scaleTargetRef:
    name: {{APP}}-worker
  minReplicaCount: 0
  maxReplicaCount: 20
  pollingInterval: 10
  cooldownPeriod: 60
  triggers:
    - type: redis-list
      metadata:
        address: redis-master.redis.svc.cluster.local:6379
        listName: "{{APP}}:jobs"
        listLength: "1"
        enableTLS: "false"
      authenticationRef:
        name: {{APP}}-keda-redis-auth
