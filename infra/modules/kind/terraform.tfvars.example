# Terraform variables for kind module (using tehcyx/kind provider)

# Cluster name (default: "kind")
cluster_name = "kind"

# Whether to create the cluster using Terraform
# Set to false if you want to manage the cluster manually
create_cluster = true

# Number of worker nodes (default: 1)
worker_node_count = 1

# Configure control plane nodes
# control_plane_nodes = [
#   {
#     role = "control-plane"
#   }
# ]

# Label control-plane node as ingress-ready (for ingress controllers)
ingress_ready = false

# Extra port mappings for the control-plane node
# Useful for exposing services running in the cluster
# extra_port_mappings = [
#   {
#     container_port = 80
#     host_port      = 80
#     protocol       = "TCP"
#   },
#   {
#     container_port = 443
#     host_port      = 443
#     protocol       = "TCP"
#   }
# ]

# Kubernetes version (optional, requires matching node image)
# kubernetes_version = "v1.27.0"
